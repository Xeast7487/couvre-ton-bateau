---
interface Props {
  title: string
  description?: string
  image?: string
}

const {
  title,
  description = "Toiles de bateaux, toits campeur, biminis et rembourrage sur mesure en Estrie. Qualité artisanale, service local.",
  image = "/og-default.jpg"
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---
<!DOCTYPE html>
<html lang="fr-CA">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Couvre ton Bateau</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={`${title} | Couvre ton Bateau`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_CA" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

<header id="siteHeader">
  <nav>
    <a href="/" class="logo" aria-label="Couvre ton Bateau — Accueil">
      <span class="logo-anchor">⚓</span>
      <span class="logo-text">
        <strong>Couvre ton</strong>
        <em>Bateau</em>
      </span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/">Accueil</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/realisations">Réalisations</a></li>
      <li><a href="/a-propos">À propos</a></li>
    </ul>
    <div class="nav-right">
      <a href="tel:+18199000000" class="nav-phone">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 13.5 19.79 19.79 0 0 1 1.08 4.72 2 2 0 0 1 3.06 2.54h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 10.45a16 16 0 0 0 6.29 6.29l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 17l-.36-.08z"/></svg>
        819 900-0000
      </a>
      <a href="/contact" class="nav-cta">Soumission gratuite</a>
      <button class="nav-toggle" aria-label="Menu" id="navToggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>

<main>
  <slot />
</main>

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="logo-anchor">⚓</span>
        <span class="logo-text">
          <strong>Couvre ton</strong>
          <em>Bateau</em>
        </span>
      </a>
      <p>Toiles sur mesure fabriquées<br/>avec soin en Estrie depuis 1998.</p>
      <p class="footer-tagline">Sous nos toiles, l'aventure devient légende.</p>
    </div>
    <div class="footer-nav">
      <h4>Navigation</h4>
      <ul>
        <li><a href="/">Accueil</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/realisations">Réalisations</a></li>
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="footer-services">
      <h4>Nos services</h4>
      <ul>
        <li>Toits campeur</li>
        <li>Toiles de bateaux</li>
        <li>Biminis</li>
        <li>Rembourrage marine</li>
        <li>Recouvrements de plancher</li>
      </ul>
    </div>
    <div class="footer-contact">
      <h4>Nous joindre</h4>
      <a href="tel:+18199000000">819 900-0000</a>
      <a href="mailto:info@couvretonbateau.ca">info@couvretonbateau.ca</a>
      <p>Estrie, Québec</p>
      <p class="footer-zone">Service dans tout le sud du Québec</p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} Couvre ton Bateau · Tous droits réservés</p>
    <p>Conception web : <a href="/">couvretonbateau.ca</a></p>
  </div>
</footer>

<script>
  const toggle = document.getElementById('navToggle')
  const links = document.getElementById('navLinks')
  toggle?.addEventListener('click', () => {
    links?.classList.toggle('open')
    toggle.classList.toggle('active')
  })

  // Active nav link
  const currentPath = window.location.pathname
  document.querySelectorAll('.nav-links a').forEach(link => {
    const href = link.getAttribute('href')
    if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
      link.classList.add('active')
    }
  })
</script>

</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy:   #1b2c44;
  --navy2:  #243a58;
  --teal:   #1d6b78;
  --cream:  #f2ede3;
  --sand:   #e3d8c5;
  --rust:   #bf4e1e;
  --rust2:  #a8421a;
  --dark:   #1c1814;
  --mid:    #5c5147;
  --muted:  #8a7f74;
  --white:  #ffffff;

  --font-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
  --font-sans:  'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

  --shadow-sm: 0 2px 8px rgba(27,44,68,.08);
  --shadow-md: 0 6px 24px rgba(27,44,68,.12);
  --shadow-lg: 0 16px 48px rgba(27,44,68,.18);
  --radius: 4px;
  --max-w: 1180px;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-sans);
  font-size: 1rem;
  line-height: 1.65;
  color: var(--dark);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
}

img { max-width: 100%; height: auto; display: block; }
a { color: inherit; text-decoration: none; }

h1, h2, h3, h4 {
  font-family: var(--font-serif);
  line-height: 1.2;
  font-weight: 600;
  color: var(--navy);
}

/* ─── HEADER ─────────────────────────────────────── */
header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--navy);
  border-bottom: 1px solid rgba(255,255,255,.08);
  box-shadow: 0 2px 16px rgba(0,0,0,.25);
}

nav {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  gap: 0;
  height: 70px;
}

/* Logo */
.logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  text-decoration: none;
  flex-shrink: 0;
  margin-right: 2.5rem;
}
.logo-anchor {
  font-size: 1.55rem;
  line-height: 1;
  filter: drop-shadow(0 1px 2px rgba(0,0,0,.3));
}
.logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
  letter-spacing: 0.01em;
}
.logo-text strong {
  font-family: var(--font-sans);
  font-size: 0.82rem;
  font-weight: 600;
  color: rgba(255,255,255,.7);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.logo-text em {
  font-family: var(--font-serif);
  font-size: 1.35rem;
  font-weight: 700;
  font-style: italic;
  color: #fff;
  letter-spacing: 0;
}

/* Nav links */
.nav-links {
  list-style: none;
  display: flex;
  align-items: center;
  gap: 0.1rem;
  flex: 1;
}
.nav-links a {
  color: rgba(255,255,255,.75);
  padding: 0.4rem 0.9rem;
  border-radius: 3px;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.01em;
  transition: color .15s, background .15s;
  white-space: nowrap;
}
.nav-links a:hover { color: #fff; background: rgba(255,255,255,.09); }
.nav-links a.active { color: #fff; background: rgba(255,255,255,.12); }

/* Right side */
.nav-right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
  margin-left: auto;
}
.nav-phone {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: rgba(255,255,255,.7);
  font-size: 0.88rem;
  font-weight: 500;
  transition: color .15s;
  white-space: nowrap;
}
.nav-phone:hover { color: #fff; }
.nav-phone svg { flex-shrink: 0; }

.nav-cta {
  display: inline-flex;
  align-items: center;
  background: var(--rust);
  color: #fff;
  padding: 0.45rem 1.1rem;
  border-radius: 3px;
  font-size: 0.88rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  transition: background .15s;
  white-space: nowrap;
}
.nav-cta:hover { background: var(--rust2); }

.nav-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
  flex-direction: column;
  gap: 5px;
  margin-left: 0.25rem;
}
.nav-toggle span {
  display: block; width: 22px; height: 2px;
  background: rgba(255,255,255,.85); border-radius: 2px;
  transition: transform .25s, opacity .2s;
}
.nav-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-toggle.active span:nth-child(2) { opacity: 0; }
.nav-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ─── FOOTER ─────────────────────────────────────── */
footer {
  background: var(--navy);
  color: rgba(255,255,255,.75);
  margin-top: 0;
}
.footer-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 4rem 2rem 3rem;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 3rem;
}
.footer-brand img { filter: brightness(0) invert(1); margin-bottom: 1rem; }
.footer-brand p { font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.5rem; }
.footer-tagline { font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; color: rgba(255,255,255,.55); }

footer h4 {
  color: #fff;
  font-family: var(--font-sans);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  font-style: normal;
}
footer ul { list-style: none; display: flex; flex-direction: column; gap: 0.45rem; }
footer ul li { font-size: 0.9rem; }
footer a { color: rgba(255,255,255,.7); transition: color .15s; }
footer a:hover { color: #fff; }
.footer-contact a, .footer-contact p {
  display: block;
  font-size: 0.9rem;
  margin-bottom: 0.45rem;
}
.footer-contact a:first-of-type { font-size: 1.05rem; font-weight: 600; color: #fff; }
.footer-zone { font-size: 0.82rem; color: rgba(255,255,255,.45); font-style: italic; }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.1);
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 1.25rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.82rem;
  color: rgba(255,255,255,.4);
}
.footer-bottom a { color: rgba(255,255,255,.55); }

/* ─── SHARED COMPONENTS ──────────────────────────── */
.container {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 2rem;
}

.section-label {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rust);
  display: block;
  margin-bottom: 0.75rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.75rem;
  border-radius: 3px;
  font-family: var(--font-sans);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .18s;
  border: 2px solid transparent;
  text-decoration: none;
}
.btn-primary {
  background: var(--rust);
  color: #fff;
  border-color: var(--rust);
}
.btn-primary:hover {
  background: var(--rust2);
  border-color: var(--rust2);
  transform: translateY(-1px);
}
.btn-outline-light {
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,.6);
}
.btn-outline-light:hover {
  background: rgba(255,255,255,.12);
  border-color: #fff;
}
.btn-outline-dark {
  background: transparent;
  color: var(--navy);
  border-color: var(--navy);
}
.btn-outline-dark:hover {
  background: var(--navy);
  color: #fff;
}

.page-hero {
  background: var(--navy);
  padding: 4rem 2rem;
  text-align: center;
  color: #fff;
}
.page-hero h1 {
  color: #fff;
  font-size: clamp(2rem, 5vw, 3.25rem);
  margin-bottom: 0.75rem;
}
.page-hero p {
  font-size: 1.1rem;
  color: rgba(255,255,255,.75);
  max-width: 540px;
  margin: 0 auto;
}

/* ─── RESPONSIVE ─────────────────────────────────── */
@media (max-width: 900px) {
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
}
/* Footer logo */
.footer-logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  margin-bottom: 1rem;
}
.footer-logo .logo-anchor { font-size: 1.4rem; }
.footer-logo .logo-text strong { color: rgba(255,255,255,.5); font-size: 0.75rem; }
.footer-logo .logo-text em { font-size: 1.2rem; color: rgba(255,255,255,.9); }

@media (max-width: 860px) {
  .nav-phone { display: none; }
}

@media (max-width: 720px) {
  nav { padding: 0 1.25rem; height: 62px; }
  .logo { margin-right: 0; }
  .logo-text em { font-size: 1.15rem; }
  .nav-toggle { display: flex; }
  .nav-links {
    display: none;
    position: fixed;
    top: 62px;
    left: 0; right: 0;
    background: var(--navy);
    flex-direction: column;
    align-items: stretch;
    padding: 0.75rem 1.25rem 1.25rem;
    border-top: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
    gap: 0.15rem;
  }
  .nav-links.open { display: flex; }
  .nav-links a { padding: 0.7rem 0.85rem; font-size: 0.97rem; }
  .nav-right { gap: 0.5rem; }
  .nav-cta { padding: 0.4rem 0.85rem; font-size: 0.84rem; }
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; padding: 2.5rem 1.5rem 2rem; }
  .footer-bottom { flex-direction: column; gap: 0.4rem; text-align: center; padding: 1rem 1.5rem; }
}
</style>
